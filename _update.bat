@echo off
:: Включаем кодировку UTF-8, чтобы русские буквы отображались нормально
chcp 65001 > nul

echo ==================================================
echo        Скачивание обновлений из репозитория
echo ==================================================
echo.

:: Запрашиваем ветку (можно оставить пустой для main)
set /p branch="Введите ветку для скачивания (нажмите Enter для main): "

:: Если ничего не ввели, используем main по умолчанию
if "%branch%"=="" (
    set branch=main
)

echo.
echo Получаем свежие данные с удаленного сервера (fetch)...
git fetch origin

echo.
echo Сливаем изменения (pull) для ветки "%branch%"...
git pull origin %branch%

echo.
echo ==================================================
echo Готово! Обновления успешно скачаны.
echo ==================================================
pause