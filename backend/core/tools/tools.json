    {
        "name": "message_user",
        "category": "Интерфейс",
        "settings": {},
        "schema_json": {
            "type": "function",
            "function": {
                "name": "message_user",
                "description": "Написать сообщение пользователю (задать вопрос, отчитаться о выполнении или просто ответить). Этим инструментом нужно завершать задачу или приостанавливать для ответа.",
