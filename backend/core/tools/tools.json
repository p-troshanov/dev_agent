                    "type": "object",
                    "properties": {
                        "message": {
                            "type": "string",
                            "description": "Текст сообщения для пользователя."
                        },
                        "is_final": {
                            "type": "boolean",
                            "description": "Установите true, если задача полностью завершена, иначе false (если ждете ответа)."
                        }
                    },
                    "required": [
                        "message",
                        "is_final"
                    ]
                }
            }
        }
    },
