@echo off
:: Включаем кодировку UTF-8, чтобы русские буквы отображались нормально
chcp 65001 > nul

echo ==================================================
echo        Отправка обновлений в ветку main
echo ==================================================
echo.

:: Запрашиваем текст коммита через input
set /p msg="Введите название коммита (что изменили?): "

:: Проверка на пустой ввод
if "%msg%"=="" (
    echo.
    echo ОШИБКА: Название коммита не может быть пустым. Отмена.
    pause
    exit /b
)

echo.
echo Добавляем файлы...
git add .

echo.
echo Создаем коммит...
git commit -m "%msg%"

echo.
echo Отправляем на GitHub...
git push origin

echo.
echo ==================================================
echo Готово! Изменения успешно отправлены.
echo ==================================================
