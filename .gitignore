// .gitignore
# Никогда не пушь файлы с API-ключами Binance/Bybit и паролями!
.env
*.pem
secrets.json
config.local.py

# --- Frontend (Vue.js / Node) ---
node_modules/
dist/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# --- Базы данных ---
# Если используешь SQLite для дневника сделок или бэктестов
*.sqlite3
*.db

# --- Среды разработки (IDE) ---
.vscode/
.idea/
*.swp

# --- Mac/Windows системные файлы ---
.DS_Store
Thumbs.db

**/.gemini_backups
.gemini_backups/
temp/
venv/
.config_data/
workspace/